{
  "name": "@llm-wiki/graph-engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared llm-wiki graph atlas engine for the workbench and offline HTML.",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/engine.iife.js",
  "module": "./dist/engine.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/engine.esm.js",
      "default": "./dist/engine.esm.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
