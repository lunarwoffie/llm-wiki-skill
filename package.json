{
  "name": "llm-wiki-agent",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "本地运行的知识库工作台。基于 pi-agent，复用 llm-wiki-skill 内核。",
  "license": "MIT",
  "engines": {
    "node": ">=22.19.0"
  },
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta --kill-others-on-fail \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=@llm-wiki-agent/web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
